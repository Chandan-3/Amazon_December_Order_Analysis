use store;
SELECT 
    *
FROM
    december_orders;
SELECT 
    *
FROM
    december_orders
WHERE
    category = 'electronics'
LIMIT 50;

-- Questions_Practice
-- 1) Show only the first 10 records.
SELECT 
    *
FROM
    december_orders
LIMIT 10;
SELECT 
    *
FROM
    december_orders
WHERE
    region = 'WA'
LIMIT 50;
-- 3. Select important columns.
-- Display only:
-- Order_ID, Order_Date, SKU, Product_Name, Qty, Amount, Status
SELECT 
    'Order_ID, Order_Date, SKU, Product_Name, Qty, Amount, Status'
FROM
    december_orders;

-- 4. Find all delivered orders.
-- Write a query to show orders where status is Delivered.
SELECT 
    *
FROM
    december_orders
WHERE
    status = 'delivered'
LIMIT 15;

-- 5. Find all cancelled orders.
-- Write a query to show only cancelled orders.
SELECT 
    *
FROM
    december_orders
WHERE
    status = 'cancelled'
LIMIT 20;

-- 6. Find orders with amount greater than 100.
-- Write a query to show all orders where Amount is more than 100.

SELECT 
    *
FROM
    december_orders
WHERE
    amount > 100
LIMIT 20;

-- 7. Find orders where quantity is more than 2.
-- Write a query using the Qty column.
SELECT 
    *
FROM
    december_orders
WHERE
    qty > 2
LIMIT 20;

-- 8. Sort orders by highest amount.
-- Write a query to show orders from highest amount to lowest amount.
SELECT 
    *
FROM
    december_orders
ORDER BY `Amount` DESC
;

-- 9. Sort orders by latest date.
-- Write a query to show the newest orders first.

select * from december_orders
order by `order_date` desc;

-- 10. Find all orders from year 2025.
-- Write a query to filter orders from 2025 only.

select * from december_orders
where `year` = 2025;

-- Filtering Questions
-- 11. Find orders from the Electronics category.

select * from december_orders
where category = 'Electronics';

-- 12. Find orders from either Electronics or Fashion category.
-- Use IN.

select * from december_orders
where category in ('Electronics', 'Fashion');
